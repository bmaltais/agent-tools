{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bmaltais/agent-tools/tools/registry.schema.json",
  "title": "Agent Tools Registry",
  "type": "object",
  "required": ["sv", "sm", "ts", "t"],
  "additionalProperties": false,
  "properties": {
    "sv": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "sm": { "type": "integer", "minimum": 1 },
    "ts": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "t": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/tool" }
    }
  },
  "$defs": {
    "arg": {
      "type": "object",
      "required": ["k", "r", "t", "d"],
      "additionalProperties": false,
      "properties": {
        "k": { "type": "string", "minLength": 1 },
        "r": { "type": "boolean" },
        "t": { "type": "string", "minLength": 1 },
        "d": { "type": "string", "minLength": 1 }
      }
    },
    "tool": {
      "type": "object",
      "required": ["id", "bin", "st", "in", "cmd", "a", "o", "p", "s", "f", "x"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "bin": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "st": { "type": "string", "enum": ["ga", "beta", "plan"] },
        "in": { "type": "string", "minLength": 1 },
        "cmd": { "type": "string", "minLength": 1 },
        "a": { "type": "array", "items": { "$ref": "#/$defs/arg" } },
        "o": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "p": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "s": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "f": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "x": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
